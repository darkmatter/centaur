{
  "uid": "thread-quality",
  "title": "Thread Quality",
  "description": "Thread-level quality signals: TTFT, 1-shot success rate, tool error classification, retries, and per-user execution volume.",
  "tags": ["centaur", "quality"],
  "schemaVersion": 39,
  "graphTooltip": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "time": { "from": "now-6h", "to": "now" },
  "timezone": "utc",
  "templating": {
    "list": [
      {
        "name": "harness",
        "type": "custom",
        "current": { "text": "All", "value": "$__all" },
        "options": [
          { "text": "All", "value": "$__all", "selected": true },
          { "text": "amp", "value": "amp" },
          { "text": "claude-code", "value": "claude-code" },
          { "text": "codex", "value": "codex" }
        ],
        "includeAll": true,
        "allValue": ".*",
        "query": "amp,claude-code,codex"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "1-Shot Success Rate",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(agent_oneshot_total{success=\"true\", harness=~\"$harness\"}) / clamp_min(sum(agent_oneshot_total{harness=~\"$harness\"}), 1)",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "green", "value": 0.9 }
            ]
          }
        }
      }
    },
    {
      "id": 2,
      "title": "TTFT p50",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_ttft_seconds_bucket{harness=~\"$harness\"}[1h])))",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 15 }
            ]
          }
        }
      }
    },
    {
      "id": 3,
      "title": "TTFT p95",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(agent_ttft_seconds_bucket{harness=~\"$harness\"}[1h])))",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 30 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "Tool Error Rate",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(rate(agent_tool_error_categories_total[1h])) / clamp_min(sum(rate(agent_tool_calls_total[1h])), 0.001)",
          "refId": "A"
        }
      ],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.05 },
              { "color": "red", "value": 0.15 }
            ]
          }
        }
      }
    },
    {
      "id": 5,
      "title": "1-Shot Rate Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum(increase(agent_oneshot_total{success=\"true\", harness=~\"$harness\"}[1h])) / clamp_min(sum(increase(agent_oneshot_total{harness=~\"$harness\"}[1h])), 1)",
          "legendFormat": "1-shot success rate",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 6,
      "title": "TTFT Distribution Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(agent_ttft_seconds_bucket{harness=~\"$harness\"}[15m])))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.90, sum by (le) (rate(agent_ttft_seconds_bucket{harness=~\"$harness\"}[15m])))",
          "legendFormat": "p90",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum by (le) (rate(agent_ttft_seconds_bucket{harness=~\"$harness\"}[15m])))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "min": 0,
          "custom": { "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 7,
      "title": "Tool Errors by Category",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (category) (rate(agent_tool_error_categories_total[15m]))",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 20, "stacking": { "mode": "normal" } }
        }
      }
    },
    {
      "id": 8,
      "title": "Tool Errors by Tool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "topk(10, sum by (tool_name) (rate(agent_tool_error_categories_total[15m])))",
          "legendFormat": "{{tool_name}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 9,
      "title": "Execution Outcomes (1-Shot vs Multi)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (success) (rate(agent_oneshot_total{harness=~\"$harness\"}[15m]))",
          "legendFormat": "1-shot success={{success}}",
          "refId": "A"
        },
        {
          "expr": "sum by (status) (rate(agent_execution_terminal_total{harness=~\"$harness\"}[15m]))",
          "legendFormat": "terminal={{status}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15 }
        }
      }
    },
    {
      "id": 10,
      "title": "Top Users by Execution Volume",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "topk(20, sum by (user_id) (increase(agent_execution_by_user_total{harness=~\"$harness\"}[24h])))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "user_id": "User", "Value": "Executions (24h)" } } }
      ],
      "fieldConfig": {
        "defaults": { "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Executions (24h)" }, "properties": [{ "id": "custom.align", "value": "right" }] }
        ]
      }
    },
    {
      "id": 11,
      "title": "Execution Success Rate by User (24h)",
      "type": "table",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "topk(20, sum by (user_id) (increase(agent_execution_by_user_total{status=\"completed\", harness=~\"$harness\"}[24h])) / clamp_min(sum by (user_id) (increase(agent_execution_by_user_total{harness=~\"$harness\"}[24h])), 1))",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true }, "renameByName": { "user_id": "User", "Value": "Success Rate" } } }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "custom": { "align": "left" } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success Rate" }, "properties": [{ "id": "custom.align", "value": "right" }] }
        ]
      }
    },
    {
      "id": 12,
      "title": "Terminal Reasons Breakdown",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [
        {
          "expr": "sum by (terminal_reason) (increase(agent_execution_terminal_total{harness=~\"$harness\"}[24h]))",
          "legendFormat": "{{terminal_reason}}",
          "refId": "A"
        }
      ]
    }
  ]
}
