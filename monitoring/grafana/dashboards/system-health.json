{
  "uid": "system-health",
  "title": "System Health",
  "description": "Overview dashboard for Centaur stack health: error rates, turn durations, webhook volume, SSE disconnects, tool failures, and DB errors.",
  "tags": ["centaur", "health"],
  "schemaVersion": 39,
  "graphTooltip": 1,
  "editable": true,
  "fiscalYearStartMonth": 0,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "utc",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 10,
      "title": "Running",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(agent_execution_requests{status=\"running\"}) or vector(0)", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "id": 11,
      "title": "Queued",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(agent_execution_requests{status=\"queued\"}) or vector(0)", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "id": 12,
      "title": "Warm Pool",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "agent_warm_pool_containers{state=\"available\"} or vector(0)", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "id": 13,
      "title": "Delivery Backlog",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "targets": [{ "expr": "sum(agent_final_delivery_outbox{state=~\"pending|sending|retry_wait\"}) or vector(0)", "refId": "A" }],
      "options": { "colorMode": "background", "graphMode": "none", "textMode": "value_and_name" }
    },
    {
      "id": 1,
      "title": "Turn Duration",
      "description": "Recent turn durations from API logs.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "_stream:{service=\"api\"} AND event:turn_done AND duration_s:*", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 2,
      "title": "Error Rate by Service",
      "description": "All error-level logs grouped by service.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "level:error", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 3,
      "title": "Recent Errors",
      "description": "Last 50 errors across all services.",
      "type": "logs",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 12 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "level:error", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" },
      "maxDataPoints": 50
    },
    {
      "id": 4,
      "title": "Webhook Volume",
      "description": "Count of incoming webhooks over time.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "event:webhook_received", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 5,
      "title": "Slack Stream Expirations",
      "description": "When Slack SSE streams expired and triggered fallback.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "event:slack_stream_expired OR event:stream_expired_fallback", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 6,
      "title": "SSE Disconnects",
      "description": "SSE connection failures and disconnects.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 30 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "event:stream_disconnect OR event:sse_disconnect", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 7,
      "title": "Tool Call Failures",
      "description": "Failed tool calls with error messages.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 30 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "event:tool_call_completed AND success:false", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    },
    {
      "id": 8,
      "title": "pgbouncer / DB Errors",
      "description": "Database connectivity issues: pgbouncer errors, DNS failures, connection terminations.",
      "type": "logs",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 38 },
      "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" },
      "targets": [{ "datasource": { "type": "victoriametrics-logs-datasource", "uid": "victorialogs" }, "expr": "pgbouncer OR ENOTFOUND OR \"Connection terminated\"", "refId": "A" }],
      "options": { "showTime": true, "showLabels": true, "showCommonLabels": false, "wrapLogMessage": true, "prettifyLogMessage": false, "enableLogDetails": true, "sortOrder": "Descending", "dedupStrategy": "none" }
    }
  ]
}
